# ===== 基础 =====
shell /bin/zsh
confirm_os_window_close 0
enabled_layouts tall,stack,splits

# ===== 字体 =====
font_family Lilex Mono Nerd Font
font_size 15.0
adjust_line_height 110%

# ===== 窗口外观 =====
# macos_titlebar_color background
window_padding_width 8
background_opacity 1.0

# ===== Tab 栏 =====
tab_bar_edge top
tab_bar_style powerline
tab_powerline_style slanted
tab_title_template "{index}: {title}"

# ===== 光标 =====
cursor_shape block
cursor_blink_interval 0

# ===== 滚动 =====
scrollback_lines 10000

# ===== 快捷键：Tab 管理 =====
map cmd+t new_tab
map cmd+w close_tab
map cmd+shift+] next_tab
map cmd+shift+[ previous_tab
map cmd+1 goto_tab 1
map cmd+2 goto_tab 2
map cmd+3 goto_tab 3
map cmd+4 goto_tab 4
map cmd+5 goto_tab 5
map cmd+6 goto_tab 6
map cmd+7 goto_tab 7
map cmd+8 goto_tab 8
map cmd+9 goto_tab 9

# ===== 快捷键：窗口 / Split 管理 =====
map cmd+enter new_window
map cmd+d launch --location=vsplit
map cmd+shift+d launch --location=hsplit
map cmd+shift+w close_window
map cmd+alt+h neighboring_window left
map cmd+alt+j neighboring_window down
map cmd+alt+k neighboring_window up
map cmd+alt+l neighboring_window right

# ===== 快捷键：布局 =====
map cmd+shift+l next_layout


# BEGIN_KITTY_THEME
# Tokyo Night Moon
include current-theme.conf
# END_KITTY_THEME