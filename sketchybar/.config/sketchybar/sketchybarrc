# A simple sketchybar config for aerospace users to get started with
# Not too different from the base starting config!

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items" 
##### Bar Appearance #####
# Configuring the general appearance of the bar.
# These are only some of the options available. For all options see:
# https://felixkratz.github.io/SketchyBar/config/bar
# If you are looking for other colors, see the color picker:
# https://felixkratz.github.io/SketchyBar/config/tricks#color-picker

# 浮动圆角状态栏：左右留边，顶部略微下移，使用半透明背景避免矩形 blur 溢出圆角。
sketchybar --bar position=top height=36 margin=4 y_offset=3 corner_radius=12 blur_radius=0 color=0x60000000 border_width=1 border_color=0x88ffffff

# 自定义工作区和状态项使用的字体。
# 字体名称需要和 ~/Library/Fonts 中实际安装的字体保持一致。
APP_FONT="sketchybar-app-font"
ICON_FONT="Symbols Nerd Font"
TEXT_FONT="SF Pro"

# items/front_app.sh 会读取主配置里定义的 FONT。
FONT="$TEXT_FONT"

# 固定 SketchyBar 中工作区的显示顺序，不依赖 Aerospace 返回顺序。
WORKSPACES=(1 2 3 Q W E)

# Apple 菜单：放在所有 left item 之前，确保它显示在状态栏最左侧。
# popup 里的项目只负责执行系统动作，执行后立即关闭菜单。
POPUP_OFF="sketchybar --set apple.logo popup.drawing=off"
POPUP_CLICK_SCRIPT="sketchybar --set \$NAME popup.drawing=toggle"

apple_logo=(
  icon=""
  icon.font="$TEXT_FONT:Black:22.0"
  icon.color=0xffffffff
  label.drawing=off
  padding_left=-7
  padding_right=12
  popup.background.color=0x88000000
  popup.background.corner_radius=8
  popup.background.border_width=1
  popup.background.border_color=0x88ffffff
  click_script="$POPUP_CLICK_SCRIPT"
)

apple_prefs=(
  icon="⚙"
  icon.font="$ICON_FONT:Regular:14.0"
  label="Preference"
  click_script="open -b com.apple.systempreferences; $POPUP_OFF"
)

apple_lock=(
  icon=""
  icon.font="$ICON_FONT:Regular:14.0"
  label="Lock Screen"
  click_script="osascript -e 'tell application \"System Events\" to keystroke \"q\" using {control down, command down}'; $POPUP_OFF"
)

apple_sleep=(
  icon="⏾"
  icon.font="$ICON_FONT:Regular:14.0"
  label="Sleep"
  click_script="pmset sleepnow; $POPUP_OFF"
)

##### Changing Defaults #####
# We now change some default values, which are applied to all further items.
# For a full list of all available item properties see:
# https://felixkratz.github.io/SketchyBar/config/items

default=(
  padding_left=5
  padding_right=5
  icon.font="$ICON_FONT:Regular:15.0"
  label.font="$TEXT_FONT:Semibold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=4
  icon.padding_right=4
  label.padding_left=4
  label.padding_right=4
  updates=on
)
sketchybar --default "${default[@]}"

# 添加左侧 Apple popup 菜单。
sketchybar --add item apple.logo left \
  --set apple.logo "${apple_logo[@]}" \
  --add item apple.prefs popup.apple.logo \
  --set apple.prefs "${apple_prefs[@]}" \
  --add item apple.lock popup.apple.logo \
  --set apple.lock "${apple_lock[@]}" \
  --add item apple.sleep popup.apple.logo \
  --set apple.sleep "${apple_sleep[@]}"

##### Adding aeropsace layouts #####

# Add the aerospace_workspace_change event we specified in aerospace.toml
sketchybar --add event aerospace_workspace_change

# Add workspaces for all monitors
# 查询 Aerospace 时使用 monitor-id，绑定 SketchyBar display 时使用 AppKit screen id。
while IFS='|' read -r monitor display_id; do
  for sid in "${WORKSPACES[@]}"; do
    if ! aerospace list-workspaces --monitor "$monitor" | grep -qx "$sid"; then
      continue
    fi
    sketchybar --add item space.$sid left \
      --set space.$sid display="$display_id" \
      --set space.$sid \
      drawing=on \
      background.color=0x44ffffff \
      background.corner_radius=5 \
      background.drawing=on \
      background.border_color=0xAAFFFFFF \
      background.border_width=0 \
      background.height=25 \
      icon="$sid" \
      icon.font="$TEXT_FONT:Semibold:14.0" \
      icon.padding_left=10 \
      icon.shadow.distance=4 \
      icon.shadow.color=0xA0000000 \
      label.font="$APP_FONT:Regular:13.0" \
      label.padding_right=14 \
      label.padding_left=0 \
      label.y_offset=-1 \
      label.shadow.drawing=off \
      label.shadow.color=0xA0000000 \
      label.shadow.distance=4 \
      click_script="aerospace workspace $sid"
  done
done <<<"$(aerospace list-monitors --format "%{monitor-id}|%{monitor-appkit-nsscreen-screens-id}")"

# 用一个隐藏 item 统一处理工作区焦点变化。
# 避免每次切换 Aerospace 工作区时为每个 workspace 都跑一次脚本。
sketchybar --add item aerospace_workspace_handler left \
  --set aerospace_workspace_handler \
  drawing=off \
  script="$PLUGIN_DIR/aerospace_workspace_change.sh" \
  --subscribe aerospace_workspace_handler aerospace_workspace_change

# 工作区变化后异步刷新每个 workspace 的应用图标。
# 和焦点高亮拆成两个 handler，避免图标枚举拖慢切换反馈。
sketchybar --add item aerospace_workspace_icons_handler left \
  --set aerospace_workspace_icons_handler \
  drawing=off \
  script="$PLUGIN_DIR/update_workspace_icons.sh" \
  --subscribe aerospace_workspace_icons_handler aerospace_workspace_change space_windows_change

# Load Icons on startup for all monitors
# 应用图标和焦点变化分开加载，保证工作区切换响应更快。
for sid in "${WORKSPACES[@]}"; do
    # 直接读取 Aerospace 的 app-name 字段，避免解析默认表格输出。
    apps=$(aerospace list-windows --workspace "$sid" --format "%{app-name}")

    sketchybar --set space.$sid drawing=on

    icon_strip=" "
    if [ "${apps}" != "" ]; then
      while read -r app; do
        icon_strip+=" $($CONFIG_DIR/plugins/icon_map_fn.sh "$app")"
      done <<<"${apps}"
    else
      icon_strip=""
    fi
    sketchybar --set space.$sid label="$icon_strip"
done


#front app
source "$ITEM_DIR/front_app.sh"


##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# Some items refresh on a fixed cycle, e.g. the clock runs its script once
# every 10s. Other gititems respond to events they subscribe to, e.g. the
# volume.sh script is only executed once an actual change in system audio
# volume is registered. More info about the event system can be found here:
# https://felixkratz.github.io/SketchyBar/config/events

sketchybar --add event bluetooth_change "com.apple.bluetooth.status"

# AirPods 输出设备指示器。
# 脚本会检查当前声音输出设备；只有输出设备是 AirPods 时才显示。
# 这里关闭 label，只用图标作为状态提示。
airpods=(
  script="$PLUGIN_DIR/airpods.sh"
  icon="􀪷 "
  padding_right=5
  padding_left=5
  label.drawing=off
  update_freq=300
  updates=on
)

# 蓝牙状态或音量变化时刷新一次；输出设备切换通常会伴随这些事件。
sketchybar --add item clock right \
  --set clock update_freq=10 script="$PLUGIN_DIR/clock.sh" \
  --add item volume right \
  --set volume script="$PLUGIN_DIR/volume.sh" \
  --subscribe volume volume_change \
  --add item airpods right \
  --set airpods "${airpods[@]}" \
  --subscribe airpods bluetooth_change volume_change \
  --add item battery right \
  --set battery update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery system_woke power_source_change

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
